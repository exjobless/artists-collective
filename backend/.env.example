# The Artists' Collective backend — copy to .env and fill to go LIVE.
# Until APP_SECRET_KEY + NODE_RPC_URL are set, the server runs in DRY mode
# (echoes what it would submit) so the front-ends can be wired and tested.

# App-owned key — signs server-side, no user approval (Evan confirmed).
# EVAN-Q1: exact way to obtain/register. Starter path: node scripts/generate-keypair.js --env
APP_PUBKEY=
APP_SECRET_KEY=

# Usernode node wallet RPC — a sidecar `usernodelabs/usernode` container,
# pointed at its HTTP port (keep it on the private/tailnet side, never public).
NODE_RPC_URL=http://127.0.0.1:3001

TREASURY_ADDRESS=
FEE_PCT=20
PORT=8099
